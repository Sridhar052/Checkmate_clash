rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "bsridhar052@gmail.com";
    }

    // Players: Anyone can read, only the player (or admin) can update their own status
    match /players/{playerId} {
      allow read: if true;
      allow create: if true; // Players join without auth initially, or we can restrict to server
      allow update: if true; // Simplified for this arena-style app where server handles logic
      allow delete: if isAdmin();
    }

    // Games: Anyone can read, only server/admin should write (simplified for demo)
    match /games/{gameId} {
      allow read: if true;
      allow write: if true; 
    }

    // Tournament state
    match /tournament/state {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
