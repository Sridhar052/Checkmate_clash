{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "A player in the tournament",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "points": { "type": "number" },
        "wins": { "type": "number" },
        "losses": { "type": "number" },
        "draws": { "type": "number" },
        "streak": { "type": "number" },
        "isOnline": { "type": "boolean" },
        "lastActive": { "type": "number" }
      },
      "required": ["name", "points", "wins", "losses", "draws", "streak"]
    },
    "Game": {
      "title": "Game",
      "description": "A chess match between two players",
      "type": "object",
      "properties": {
        "white": { "type": "string" },
        "black": { "type": "string" },
        "whiteName": { "type": "string" },
        "blackName": { "type": "string" },
        "fen": { "type": "string" },
        "status": { "type": "string", "enum": ["ongoing", "completed"] },
        "winner": { "type": "string" },
        "startTime": { "type": "number" },
        "whiteTime": { "type": "number" },
        "blackTime": { "type": "number" },
        "lastMoveTime": { "type": "number" }
      },
      "required": ["white", "black", "fen", "status", "startTime"]
    },
    "Tournament": {
      "title": "Tournament",
      "description": "Global tournament state",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["waiting", "active", "ended"] },
        "startTime": { "type": "number" },
        "endTime": { "type": "number" },
        "duration": { "type": "number" }
      },
      "required": ["status", "duration"]
    }
  },
  "firestore": {
    "/players/{playerId}": { "schema": "Player", "description": "Player profiles" },
    "/games/{gameId}": { "schema": "Game", "description": "Match records" },
    "/tournament/state": { "schema": "Tournament", "description": "Tournament status" }
  }
}
